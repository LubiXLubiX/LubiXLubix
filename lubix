<?php

declare(strict_types=1);

$autoload = __DIR__ . '/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "LubiX root dependencies are not installed.\n");
    fwrite(STDERR, "Run: composer update\n");
    exit(1);
}

require $autoload;

$app = new \Lubix\Cli\Console\Application();
exit($app->run($_SERVER['argv'] ?? $argv ?? []));
